# Copy to .env and fill in. .env is gitignored — never commit real tokens.

# Sketchfab Data API v3 token — enables the in-app "Search Sketchfab library"
# replace flow and the tools/sketchfab-*.mjs curation/fetch scripts.
# Get one at https://sketchfab.com/settings/password (API section).
# The Vite dev server injects this server-side; it never enters the client bundle.
SKETCHFAB_API_TOKEN=
